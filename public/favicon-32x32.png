<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 32 32" width="32" height="32">
  <defs>
    <linearGradient id="grad1" x1="0%" y1="0%" x2="100%" y2="100%">
      <stop offset="0%" style="stop-color:#1e40af;stop-opacity:1" />
      <stop offset="100%" style="stop-color:#3b82f6;stop-opacity:1" />
    </linearGradient>
  </defs>
  
  <!-- Background circle -->
  <circle cx="16" cy="16" r="14" fill="url(#grad1)" stroke="#1e3a8a" stroke-width="1"/>
  
  <!-- Document icon -->
  <rect x="8" y="6" width="12" height="16" fill="white" rx="1"/>
  
  <!-- Lines on document -->
  <rect x="10" y="9" width="8" height="1" fill="#1e40af"/>
  <rect x="10" y="12" width="8" height="1" fill="#1e40af"/>
  <rect x="10" y="15" width="6" height="1" fill="#1e40af"/>
  
  <!-- AI dot/indicator -->
  <circle cx="18" cy="18" r="3" fill="#10b981"/>
  <circle cx="18" cy="18" r="1.5" fill="white"/>
</svg>
