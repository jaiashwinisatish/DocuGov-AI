<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 16 16" width="16" height="16">
  <defs>
    <linearGradient id="grad1" x1="0%" y1="0%" x2="100%" y2="100%">
      <stop offset="0%" style="stop-color:#1e40af;stop-opacity:1" />
      <stop offset="100%" style="stop-color:#3b82f6;stop-opacity:1" />
    </linearGradient>
  </defs>
  
  <!-- Background circle -->
  <circle cx="8" cy="8" r="7" fill="url(#grad1)" stroke="#1e3a8a" stroke-width="0.5"/>
  
  <!-- Document icon -->
  <rect x="4" y="3" width="6" height="8" fill="white" rx="0.5"/>
  
  <!-- Lines on document -->
  <rect x="5" y="4.5" width="4" height="0.5" fill="#1e40af"/>
  <rect x="5" y="6" width="4" height="0.5" fill="#1e40af"/>
  <rect x="5" y="7.5" width="3" height="0.5" fill="#1e40af"/>
  
  <!-- AI dot/indicator -->
  <circle cx="9" cy="9" r="1.5" fill="#10b981"/>
  <circle cx="9" cy="9" r="0.75" fill="white"/>
</svg>
